#!name=小红书 Feed 时间 - JQ 诊断
#!desc=用 http-response-jq 验证能否修改 homefeed（单引号包裹 jq）
#!author=rednote-feed-time
#!system=ios

[Body Rewrite]
http-response-jq ^https?:\/\/[a-z]+\.xiaohongshu\.com\/api\/sns\/v\d+\/homefeed\? 'if (.data | type) == "array" then .data[] |= if .model_type == "note" and .display_title then .display_title = "✅ " + .display_title else . end else . end'

[MITM]
hostname = %APPEND% *.xiaohongshu.com
