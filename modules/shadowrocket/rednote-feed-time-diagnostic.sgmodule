#!name=小红书 Feed 时间 - 诊断
#!desc=诊断模块：将第一条笔记标题替换为 ✅DIAG-xxxxxx，验证拦截是否生效
#!author=rednote-feed-time
#!system=ios

[Script]
rednote-feed-time-diagnostic = type=http-response,pattern=^https:\/\/rec\.xiaohongshu\.com\/api\/sns\/v6\/homefeed,script-path=https://raw.githubusercontent.com/meichiny/rednote-feed-time/shadowrocket-module/modules/shadowrocket/rednote-feed-time-test.js,requires-body=true,max-size=-1,timeout=60

[MITM]
hostname = %APPEND% rec.xiaohongshu.com
