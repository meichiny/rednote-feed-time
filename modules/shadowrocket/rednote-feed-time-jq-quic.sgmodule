#!name=小红书 Feed 时间 - JQ 诊断 (含QUIC阻断)
#!desc=含 QUIC/UDP 阻断 + http-response-jq 验证
#!author=rednote-feed-time
#!system=ios

[Rule]
AND,((PROTOCOL,UDP),(DST-PORT,443),(DOMAIN-SUFFIX,xiaohongshu.com)),REJECT

[Body Rewrite]
http-response-jq ^https?:\/\/[a-z]+\.xiaohongshu\.com\/api\/sns\/v\d+\/homefeed\? path=$.data[0].id | .data[] |= if .model_type == "note" and .display_title then .display_title = "✅ " + .display_title else . end

[MITM]
hostname = %APPEND% *.xiaohongshu.com
