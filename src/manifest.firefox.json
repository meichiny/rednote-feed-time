{
  "manifest_version": 3,
  "name": "RedNote Feed Time",
  "version": "1.1.0",
  "description": "Shows the generation time of notes on Xiaohongshu (RedNote) feeds by decoding the note ID.",
  "host_permissions": [
    "https://www.xiaohongshu.com/explore*",
    "https://www.xiaohongshu.com/user/profile/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.xiaohongshu.com/explore*",
        "https://www.xiaohongshu.com/user/profile/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "@rednote-feed-time",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
