{
  "manifest_version": 3,
  "name": "RedNote Feed Time",
  "version": "1.2.0",
  "description": "Shows the generation time of notes on Xiaohongshu (RedNote) feeds by decoding the note ID.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "RedNote Feed Time"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.xiaohongshu.com/explore*",
    "https://www.xiaohongshu.com/user/profile/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.xiaohongshu.com/explore*",
        "https://www.xiaohongshu.com/user/profile/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon.png"
  }
}
